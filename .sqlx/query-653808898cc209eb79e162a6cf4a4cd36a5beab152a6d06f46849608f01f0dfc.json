  "query": "\n            SELECT id, source as \"source: serde_json::Value\", parser, prompt, content,\n                embedding as \"embedding: Vector\",\n                created_at as \"created_at: jiff_sqlx::Timestamp\"\n            FROM perception\n            WHERE source = $1 AND parser = $2\n            AND (prompt IS NOT DISTINCT FROM $3)\n            ",
